{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "packages": {
    ".": {
      "release-type": "simple",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/marketplace.json",
          "jsonpath": "$.metadata.version"
        }
      ]
    },
    "plugins/agent-rules": {
      "release-type": "simple",
      "component": "agent-rules",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "/.claude-plugin/marketplace.json",
          "jsonpath": "$.plugins[?(@.name=='agent-rules')].version"
        }
      ]
    },
    "plugins/tmux-notify": {
      "release-type": "simple",
      "component": "tmux-notify",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "/.claude-plugin/marketplace.json",
          "jsonpath": "$.plugins[?(@.name=='tmux-notify')].version"
        }
      ]
    },
    "plugins/macos-notify": {
      "release-type": "simple",
      "component": "macos-notify",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "/.claude-plugin/marketplace.json",
          "jsonpath": "$.plugins[?(@.name=='macos-notify')].version"
        }
      ]
    }
  }
}
